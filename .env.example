# ============================================================
# LLM Providers – điền key của provider bạn đang dùng
# ============================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dbname

# ============================================================
# App
# ============================================================
APP_ENV=development       # development | staging | production
LOG_LEVEL=INFO
PORT=8000
