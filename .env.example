# ──────────────────────────────────────────────────────────────
# LLM Providers – fill in the key(s) for the provider you use
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
MEGALLM_API_KEY=sk-mega-6
# Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENV=development
# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=northwind

# Legacy fallback names (optional, keep empty if using DB_* above)
HOST=
USER=
PASSWORD=
DATABASE=

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
APP_ENV=development       # development | staging | production
LOG_LEVEL=INFO
PORT=8000                # App server port (không phải DB_PORT)
